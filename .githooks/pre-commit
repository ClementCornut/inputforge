#!/usr/bin/env bash
set -e

echo "==> Checking formatting..."
cargo fmt --all -- --check

echo "==> Running clippy (default features / gui-egui)..."
cargo clippy --all-targets -- -D warnings

echo "==> Running clippy (gui-dioxus)..."
cargo clippy --all-targets --no-default-features --features gui-dioxus -- -D warnings

echo "==> Pre-commit checks passed."

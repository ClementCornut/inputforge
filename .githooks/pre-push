#!/usr/bin/env bash
set -e

COVERAGE_THRESHOLD=90
REGION_THRESHOLD=85

# Check cargo-llvm-cov is installed
if ! command -v cargo-llvm-cov &> /dev/null; then
  echo "ERROR: cargo-llvm-cov is not installed."
  echo "Install with: cargo install cargo-llvm-cov"
  echo "Also ensure llvm-tools-preview is installed: rustup component add llvm-tools-preview"
  exit 1
fi

# Check cargo-nextest is installed
if ! command -v cargo-nextest &> /dev/null; then
  echo "ERROR: cargo-nextest is not installed."
  echo "Install with: cargo install cargo-nextest"
  exit 1
fi

IGNORE_ARGS=()
if [ -d "lambdas" ]; then
  IGNORE_ARGS=(--ignore-filename-regex 'lambdas[/\\].*[/\\]src[/\\]main\.rs$')
fi

echo "==> Running tests with coverage (lines: ${COVERAGE_THRESHOLD}%, regions: ${REGION_THRESHOLD}%)..."
cargo llvm-cov nextest --all-features --workspace "${IGNORE_ARGS[@]}" --no-report
cargo llvm-cov report "${IGNORE_ARGS[@]}" --fail-under-lines $COVERAGE_THRESHOLD
cargo llvm-cov report "${IGNORE_ARGS[@]}" --fail-under-regions $REGION_THRESHOLD

echo "==> Coverage check passed (lines >= ${COVERAGE_THRESHOLD}%, regions >= ${REGION_THRESHOLD}%)."
